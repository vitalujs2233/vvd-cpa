name: Deploy to GitHub Pages

on:
  push:
    branches:
      - main # Укажите название вашей главной ветки (main или master)

permissions:
  contents: write

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Install Node.js
        uses: actions/setup-node@v4
        with:
          node-size: 20

      - name: Install dependencies
        run: npm install

      - name: Build project
        run: npm run build

      - name: Deploy to GitHub Pages
        uses: JamesIves/github-pages-deploy-action@v4
        with:
          folder: dist # Папка, которую нужно опубликовать
          branch: gh-pages # Ветка, куда запишется готовая сборка
