{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Режим сборщика */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Проверки качества кода */
    "strict": true,
    "noUnusedLocals": false,        // Изменено на false, чтобы неиспользуемые импорты не ломали сборку
    "noUnusedParameters": false,    // Изменено на false, чтобы неиспользуемые параметры не ломали сборку
    "noFallthroughCasesInSwitch": true,

    /* Настройка алиасов для TypeScript */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
