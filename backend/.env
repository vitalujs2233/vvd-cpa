# Шаг 4: Убедитесь, что используется порт 6543 (Transaction Pooler)
#
# Шаблон подключения:
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
#
